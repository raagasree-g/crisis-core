rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAllowedType(t) {
      return t in ['fire', 'medical', 'security', 'other'];
    }

    function isStatus(s) {
      return s in ['NEW', 'IN_PROGRESS', 'RESOLVED'];
    }

    match /alerts/{alertId} {
      allow read: if true;

      allow create: if request.resource.data.keys().hasOnly([
          'type', 'room', 'note', 'status', 'createdAt', 'acceptedAt', 'resolvedAt', 'assignedTo', 'createdBy'
        ])
        && isAllowedType(request.resource.data.type)
        && request.resource.data.room is string
        && request.resource.data.room.size() > 0
        && request.resource.data.room.size() <= 10
        && request.resource.data.note is string
        && request.resource.data.note.size() <= 140
        && request.resource.data.status == 'NEW'
        && request.resource.data.assignedTo == null
        && request.resource.data.acceptedAt == null
        && request.resource.data.resolvedAt == null
        && request.resource.data.createdBy is string;

      allow update: if isStatus(resource.data.status)
        && isStatus(request.resource.data.status)
        && request.resource.data.type == resource.data.type
        && request.resource.data.room == resource.data.room
        && request.resource.data.note == resource.data.note
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.createdBy == resource.data.createdBy
        && (
          (
            resource.data.status == 'NEW'
            && request.resource.data.status == 'IN_PROGRESS'
            && request.resource.data.assignedTo is string
            && request.resource.data.acceptedAt != null
            && request.resource.data.resolvedAt == resource.data.resolvedAt
            && request.resource.data.keys().hasOnly([
              'type', 'room', 'note', 'status', 'createdAt', 'acceptedAt', 'resolvedAt', 'assignedTo', 'createdBy'
            ])
          )
          ||
          (
            resource.data.status == 'IN_PROGRESS'
            && request.resource.data.status == 'RESOLVED'
            && request.resource.data.assignedTo == resource.data.assignedTo
            && request.resource.data.acceptedAt == resource.data.acceptedAt
            && request.resource.data.resolvedAt != null
            && request.resource.data.keys().hasOnly([
              'type', 'room', 'note', 'status', 'createdAt', 'acceptedAt', 'resolvedAt', 'assignedTo', 'createdBy'
            ])
          )
        );

      allow delete: if false;
    }
  }
}

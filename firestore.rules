rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAllowedType(t) {
      return t in ['fire', 'medical', 'security', 'other'];
    }

    match /alerts/{alertId} {
      allow read: if true;

      allow create: if request.resource.data.keys().hasOnly([
          'type', 'room', 'note', 'status', 'createdAt', 'updatedAt'
        ])
        && isAllowedType(request.resource.data.type)
        && request.resource.data.room is string
        && request.resource.data.room.size() > 0
        && request.resource.data.room.size() <= 10
        && request.resource.data.note is string
        && request.resource.data.note.size() <= 140
        && request.resource.data.status == 'new';

      allow update: if resource.data.status in ['new', 'in_progress']
        && request.resource.data.type == resource.data.type
        && request.resource.data.room == resource.data.room
        && request.resource.data.note == resource.data.note
        && request.resource.data.createdAt == resource.data.createdAt
        && (
          (resource.data.status == 'new'
            && request.resource.data.status == 'in_progress'
            && request.resource.data.keys().hasOnly([
              'type', 'room', 'note', 'status', 'createdAt', 'updatedAt'
            ])
          )
          ||
          (resource.data.status == 'in_progress'
            && request.resource.data.status == 'resolved'
            && request.resource.data.keys().hasOnly([
              'type', 'room', 'note', 'status', 'createdAt', 'updatedAt', 'resolvedAt'
            ])
          )
        );

      allow delete: if false;
    }
  }
}
